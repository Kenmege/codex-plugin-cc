{
  "name": "codex-plugin-cc",
  "version": "1.0.13",
  "type": "module",
  "description": "Codex-native Claude review plugin: agentic Opus 4.7 reviewers, including explicit Opus 4.7 1M long-context mode, with full read-only tool access for high-scrutiny code review, adversarial review, deep multi-agent review, and security-focused review.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kenmege/codex-plugin-cc.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "bin": {
    "codex-claude-review": "scripts/claude-review-companion.mjs"
  },
  "files": [
    ".agents/",
    ".codex-plugin/",
    "commands/",
    "schemas/",
    "scripts/claude-review-companion.mjs",
    "scripts/bin/",
    "scripts/lib/",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "NOTICE",
    "docs/architecture.md"
  ],
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "lint": "node scripts/validate-repo.mjs",
    "test": "node --test test/*.test.mjs",
    "check": "npm run lint && npm test",
    "pack:check": "npm pack --dry-run"
  },
  "keywords": [
    "codex",
    "plugin",
    "claude",
    "claude-code",
    "review",
    "opus",
    "sonnet",
    "agentic",
    "adversarial-review",
    "deep-review",
    "security-review"
  ]
}
