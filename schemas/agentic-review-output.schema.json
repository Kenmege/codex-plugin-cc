{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "verdict",
    "ship_recommendation",
    "executive_summary",
    "systemic_risks",
    "findings",
    "blind_spots",
    "verified_claims",
    "exploration_log",
    "next_steps"
  ],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": [
        "OK",
        "REQUEST_CHANGES"
      ]
    },
    "ship_recommendation": {
      "type": "string",
      "enum": [
        "SHIP",
        "NO_SHIP"
      ]
    },
    "executive_summary": {
      "type": "string",
      "minLength": 1
    },
    "systemic_risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "confidence",
          "risk_category",
          "title",
          "body",
          "failure_scenario",
          "why_vulnerable",
          "impact",
          "exploitability",
          "file",
          "line_start",
          "line_end",
          "recommendation",
          "test_gap",
          "evidence"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "minLength": 1
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "risk_category": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "body": {
            "type": "string",
            "minLength": 1
          },
          "failure_scenario": {
            "type": "string",
            "minLength": 1
          },
          "why_vulnerable": {
            "type": "string",
            "minLength": 1
          },
          "impact": {
            "type": "string",
            "minLength": 1
          },
          "exploitability": {
            "type": "string",
            "minLength": 1
          },
          "file": {
            "type": "string",
            "minLength": 1
          },
          "line_start": {
            "type": [
              "integer",
              "null"
            ]
          },
          "line_end": {
            "type": [
              "integer",
              "null"
            ]
          },
          "recommendation": {
            "type": "string",
            "minLength": 1
          },
          "test_gap": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "tool",
                "query",
                "confirmed"
              ],
              "properties": {
                "tool": {
                  "type": "string",
                  "minLength": 1
                },
                "query": {
                  "type": "string",
                  "minLength": 1
                },
                "confirmed": {
                  "type": "string",
                  "minLength": 1
                },
                "source": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    },
    "verified_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim",
          "verification"
        ],
        "properties": {
          "claim": {
            "type": "string",
            "minLength": 1
          },
          "verification": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "blind_spots": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "exploration_log": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step",
          "tool",
          "rationale"
        ],
        "properties": {
          "step": {
            "type": "integer",
            "minimum": 1
          },
          "tool": {
            "type": "string",
            "minLength": 1
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          },
          "outcome": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "next_steps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
